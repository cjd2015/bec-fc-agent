# BEC Agent - Environment Variables Example
# 版本: 1.0
# 更新时间: 2026-03-31

# ---------------------------------
# App Basic
# ---------------------------------
APP_NAME=BEC Agent
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1

# ---------------------------------
# Database
# ---------------------------------
DB_DRIVER=postgresql
DB_HOST=your-ecs-ip-or-domain
DB_PORT=5432
DB_NAME=bec_agent
DB_USER=bec_user
DB_PASSWORD=change_this_to_a_strong_password
DB_SSL_MODE=prefer

# ---------------------------------
# JWT / Auth
# ---------------------------------
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------------------------------
# AI Model
# ---------------------------------
MODEL_PROVIDER=qwen
MODEL_BASE_URL=https://your-model-endpoint
MODEL_API_KEY=change_this_to_your_model_api_key
MODEL_NAME=your_model_name
MODEL_TIMEOUT_SECONDS=60

# ---------------------------------
# CORS
# ---------------------------------
CORS_ALLOW_ORIGINS=https://datahive.top,https://www.datahive.top
CORS_ALLOW_CREDENTIALS=true

# ---------------------------------
# Logging
# ---------------------------------
LOG_LEVEL=INFO
LOG_SQL=false

# ---------------------------------
# File / Content
# ---------------------------------
UPLOAD_DIR=/tmp/uploads
MAX_UPLOAD_SIZE_MB=10

# ---------------------------------
# Optional Redis (future)
# ---------------------------------
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------------------------------
# Security
# ---------------------------------
ENABLE_SECURITY_HEADERS=true
TRUST_PROXY=true
