# BEC Agent Frontend Environment Variables Example
# 版本: 1.0
# 更新时间: 2026-03-31

# ---------------------------------
# Frontend App
# ---------------------------------
VITE_APP_NAME=BEC Agent
VITE_APP_ENV=production

# ---------------------------------
# API
# ---------------------------------
VITE_API_BASE_URL=/api/v1

# ---------------------------------
# Feature Flags
# ---------------------------------
VITE_ENABLE_SCENE_TRAINING=true
VITE_ENABLE_MOCK_EXAM=true
VITE_ENABLE_RECOMMENDATION=false
VITE_ENABLE_POINTS=false

# ---------------------------------
# Upload / Static
# ---------------------------------
VITE_MAX_UPLOAD_SIZE_MB=10

# ---------------------------------
# Security / Runtime
# ---------------------------------
VITE_ENABLE_CONSOLE_LOG=false
